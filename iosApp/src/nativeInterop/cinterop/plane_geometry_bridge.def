headers = PlaneGeometryBridge.h
headerFilter = PlaneGeometryBridge.h
package = com.example.arplitka.iosapp.bridge
language = Objective-C
compilerOpts = -framework ARKit -framework Foundation -framework SceneKit -framework UIKit
linkerOpts = -framework ARKit -framework Foundation -framework SceneKit -framework UIKit

---

#import <ARKit/ARKit.h>
#import <SceneKit/SceneKit.h>
#import <UIKit/UIKit.h>
#import <math.h>
#import <stdint.h>
#import <stdlib.h>
#import <string.h>
#import "PlaneGeometryBridge.h"

static ARPlaneAnchor *PGCast(void *planeAnchor) {
    if (planeAnchor == NULL) {
        return NULL;
    }
    return (__bridge ARPlaneAnchor *)planeAnchor;
}

static ARSession *PGSessionCast(void *sessionPtr) {
    if (sessionPtr == NULL) {
        return NULL;
    }
    return (__bridge ARSession *)sessionPtr;
}

static ARFrame *PGFrameCast(void *framePtr) {
    if (framePtr == NULL) {
        return NULL;
    }
    return (__bridge ARFrame *)framePtr;
}

static float PGDistanceBetweenTransforms(simd_float4x4 fromTransform, simd_float4x4 toTransform) {
    simd_float4 fromPos = fromTransform.columns[3];
    simd_float4 toPos = toTransform.columns[3];
    float dx = toPos.x - fromPos.x;
    float dy = toPos.y - fromPos.y;
    float dz = toPos.z - fromPos.z;
    return sqrtf((dx * dx) + (dy * dy) + (dz * dz));
}

bool pg_world_transform_from_column_major(const float *in16, simd_float4x4 *outMatrix) {
    if (in16 == NULL || outMatrix == NULL) {
        return false;
    }
    memcpy(outMatrix, in16, sizeof(simd_float4x4));
    return true;
}

ARAnchor *pg_session_add_anchor_from_column_major(void *sessionPtr, const float *in16) {
    ARSession *session = PGSessionCast(sessionPtr);
    if (session == NULL || in16 == NULL) {
        return NULL;
    }
    simd_float4x4 transform;
    if (!pg_world_transform_from_column_major(in16, &transform)) {
        return NULL;
    }
    ARAnchor *anchor = [[ARAnchor alloc] initWithTransform:transform];
    if (anchor == NULL) {
        return NULL;
    }
    [session addAnchor:anchor];
    return anchor;
}

static void PGCopyMatrix(simd_float4x4 matrix, float *out16) {
    if (out16 == NULL) {
        return;
    }
    for (int column = 0; column < 4; column++) {
        simd_float4 values = matrix.columns[column];
        out16[(column * 4) + 0] = values.x;
        out16[(column * 4) + 1] = values.y;
        out16[(column * 4) + 2] = values.z;
        out16[(column * 4) + 3] = values.w;
    }
}

// ARRaycastTargetMesh (= 1 << 2) is iOS 14+; cinterop indexer may not see the symbol.
#define PG_RAYCAST_TARGET_MESH ((ARRaycastTarget)(1 << 2))

static ARRaycastTarget PGTargetForKind(int targetKind) {
    if (targetKind == PG_RAYCAST_ESTIMATED_PLANE) {
        return ARRaycastTargetEstimatedPlane;
    }
    if (targetKind == PG_RAYCAST_MESH) {
        if (@available(iOS 14.0, *)) {
            return PG_RAYCAST_TARGET_MESH;
        }
        return ARRaycastTargetEstimatedPlane;
    }
    return ARRaycastTargetExistingPlaneGeometry;
}

bool pg_session_supports_mesh_raycast(void *sessionPtr) {
    ARSession *session = PGSessionCast(sessionPtr);
    if (session == NULL) {
        return NO;
    }
    if (@available(iOS 14.0, *)) {
        ARConfiguration *config = session.configuration;
        if (config == NULL) {
            return NO;
        }
        if ([config isKindOfClass:[ARWorldTrackingConfiguration class]]) {
            ARWorldTrackingConfiguration *worldConfig = (ARWorldTrackingConfiguration *)config;
            return worldConfig.sceneReconstruction == ARSceneReconstructionMesh;
        }
    }
    return NO;
}

bool pg_center_raycast(
    void *sessionPtr,
    void *framePtr,
    float screenX,
    float screenY,
    int targetKind,
    float *outDistance,
    float *outWorldTransform16,
    char *outAnchorUuid,
    int outAnchorUuidCapacity
) {
    if (outDistance == NULL || outWorldTransform16 == NULL) {
        return NO;
    }
    *outDistance = 0.0f;
    if (outAnchorUuid != NULL && outAnchorUuidCapacity > 0) {
        outAnchorUuid[0] = '\0';
    }
    memset(outWorldTransform16, 0, sizeof(float) * 16u);

    ARSession *session = PGSessionCast(sessionPtr);
    ARFrame *frame = PGFrameCast(framePtr);
    if (session == NULL || frame == NULL) {
        return NO;
    }
    if (@available(iOS 13.0, *)) {
        CGPoint screenPoint = CGPointMake((CGFloat)screenX, (CGFloat)screenY);
        ARRaycastQuery *query = [frame raycastQueryFromPoint:screenPoint
                                              allowingTarget:PGTargetForKind(targetKind)
                                                   alignment:ARRaycastTargetAlignmentHorizontal];
        if (query == NULL) {
            return NO;
        }
        NSArray<ARRaycastResult *> *results = [session raycast:query];
        ARRaycastResult *best = results.firstObject;
        if (best == NULL) {
            return NO;
        }
        ARAnchor *anchor = best.anchor;
        if (anchor != NULL && outAnchorUuid != NULL && outAnchorUuidCapacity > 0) {
            NSString *uuidString = anchor.identifier.UUIDString;
            if (uuidString != NULL) {
                strncpy(outAnchorUuid, uuidString.UTF8String, (size_t)(outAnchorUuidCapacity - 1));
                outAnchorUuid[outAnchorUuidCapacity - 1] = '\0';
            }
        }
        PGCopyMatrix(best.worldTransform, outWorldTransform16);
        *outDistance = PGDistanceBetweenTransforms(frame.camera.transform, best.worldTransform);
        return YES;
    }
    return NO;
}

// Raw ARPlaneAnchor.classification values (cinterop may not expose ARPlaneAnchorClassification* symbols).
#define PG_IOS_ANCHOR_CLASS_NONE (-1)
#define PG_IOS_ANCHOR_CLASS_UNKNOWN 0
#define PG_IOS_ANCHOR_CLASS_WALL 1
#define PG_IOS_ANCHOR_CLASS_FLOOR 2
#define PG_IOS_ANCHOR_CLASS_CEILING 3
#define PG_IOS_ANCHOR_CLASS_TABLE 4
#define PG_IOS_ANCHOR_CLASS_SEAT 5
#define PG_IOS_ANCHOR_CLASS_DOOR 6
#define PG_IOS_ANCHOR_CLASS_WINDOW 7

int pg_plane_classification(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    if (anchor == NULL) {
        return PG_PLANE_CLASSIFICATION_NONE;
    }
    if (@available(iOS 12.0, *)) {
        NSInteger raw = anchor.classification;
        switch (raw) {
            case PG_IOS_ANCHOR_CLASS_WALL:
                return PG_PLANE_CLASSIFICATION_WALL;
            case PG_IOS_ANCHOR_CLASS_FLOOR:
                return PG_PLANE_CLASSIFICATION_FLOOR;
            case PG_IOS_ANCHOR_CLASS_CEILING:
                return PG_PLANE_CLASSIFICATION_CEILING;
            case PG_IOS_ANCHOR_CLASS_TABLE:
                return PG_PLANE_CLASSIFICATION_TABLE;
            case PG_IOS_ANCHOR_CLASS_SEAT:
                return PG_PLANE_CLASSIFICATION_SEAT;
            case PG_IOS_ANCHOR_CLASS_DOOR:
            case PG_IOS_ANCHOR_CLASS_WINDOW:
                return PG_PLANE_CLASSIFICATION_UNKNOWN;
            case PG_IOS_ANCHOR_CLASS_NONE:
                return PG_PLANE_CLASSIFICATION_NONE;
            case PG_IOS_ANCHOR_CLASS_UNKNOWN:
                return PG_PLANE_CLASSIFICATION_UNKNOWN;
            default:
                return PG_PLANE_CLASSIFICATION_UNKNOWN;
        }
    }
    return PG_PLANE_CLASSIFICATION_NONE;
}

bool pg_plane_is_floor_like(void *planeAnchor) {
    int classification = pg_plane_classification(planeAnchor);
    return classification == PG_PLANE_CLASSIFICATION_FLOOR ||
        classification == PG_PLANE_CLASSIFICATION_NONE;
}

static uint32_t PGHashFloat(float value) {
    uint32_t bits = 0;
    memcpy(&bits, &value, sizeof(bits));
    return bits;
}

static BOOL PGReadExtentBoundary(ARPlaneAnchor *anchor, vector_float3 *outVertices, NSUInteger *outCount) {
    if (anchor == NULL || outVertices == NULL || outCount == NULL) {
        return NO;
    }

    float width = 0.0f;
    float depth = 0.0f;
    float centerX = 0.0f;
    float centerZ = 0.0f;

    if (@available(iOS 16.0, *)) {
        width = anchor.planeExtent.width;
        depth = anchor.planeExtent.height;
    } else {
#pragma clang diagnostic push
#pragma clang diagnostic ignored "-Wdeprecated-declarations"
        width = anchor.extent.x;
        depth = anchor.extent.z;
        centerX = anchor.center.x;
        centerZ = anchor.center.z;
#pragma clang diagnostic pop
    }

    if (width <= 0.0f || depth <= 0.0f) {
        return NO;
    }

    float halfX = width * 0.5f;
    float halfZ = depth * 0.5f;
    outVertices[0] = (vector_float3){ centerX - halfX, 0.0f, centerZ - halfZ };
    outVertices[1] = (vector_float3){ centerX + halfX, 0.0f, centerZ - halfZ };
    outVertices[2] = (vector_float3){ centerX + halfX, 0.0f, centerZ + halfZ };
    outVertices[3] = (vector_float3){ centerX - halfX, 0.0f, centerZ + halfZ };
    *outCount = 4;
    return YES;
}

static BOOL PGReadPolygonBoundary(ARPlaneAnchor *anchor, const vector_float3 **outVertices, NSUInteger *outCount) {
    if (anchor == NULL || outVertices == NULL || outCount == NULL) {
        return NO;
    }

    ARPlaneGeometry *geometry = anchor.geometry;
    if (geometry != NULL && geometry.boundaryVertexCount >= 3 && geometry.boundaryVertices != NULL) {
        *outVertices = geometry.boundaryVertices;
        *outCount = geometry.boundaryVertexCount;
        return YES;
    }
    return NO;
}

static BOOL PGReadBoundary(ARPlaneAnchor *anchor, const vector_float3 **outVertices, NSUInteger *outCount, vector_float3 *fallbackVertices) {
    if (anchor == NULL || outVertices == NULL || outCount == NULL) {
        return NO;
    }

    if (PGReadPolygonBoundary(anchor, outVertices, outCount)) {
        return YES;
    }

    if (PGReadExtentBoundary(anchor, fallbackVertices, outCount)) {
        *outVertices = fallbackVertices;
        return YES;
    }
    return NO;
}

static BOOL PGPointInPolygonXZ(float x, float z, const vector_float3 *vertices, NSUInteger count) {
    if (vertices == NULL || count < 3) {
        return NO;
    }

    BOOL inside = NO;
    for (NSUInteger i = 0, j = count - 1; i < count; j = i++) {
        float xi = vertices[i].x;
        float zi = vertices[i].z;
        float xj = vertices[j].x;
        float zj = vertices[j].z;
        BOOL intersect = ((zi > z) != (zj > z)) &&
            (x < (xj - xi) * (z - zi) / ((zj - zi) + 1e-6f) + xi);
        if (intersect) {
            inside = !inside;
        }
    }
    return inside;
}

static float PGPolygonArea(const vector_float3 *vertices, NSUInteger count) {
    if (vertices == NULL || count < 3) {
        return 0.0f;
    }

    float sum = 0.0f;
    for (NSUInteger i = 0; i < count; i++) {
        NSUInteger next = (i + 1) % count;
        sum += vertices[i].x * vertices[next].z - vertices[next].x * vertices[i].z;
    }
    return fabsf(sum) * 0.5f;
}

#define PG_DOT_CIRCLE_SEGMENTS 12
#define PG_DOT_VERTICES_PER_DISC (1 + PG_DOT_CIRCLE_SEGMENTS)

typedef struct {
    float x;
    float y;
    float z;
} PGDotVertex;

static void PGWriteDotDisc(NSMutableData *vertexData, NSMutableData *indexData, int dotIndex, float x, float z, float dotRadiusM, float yOffsetM) {
    PGDotVertex center = { x, yOffsetM, z };
    PGDotVertex rim[PG_DOT_CIRCLE_SEGMENTS];
    for (int segment = 0; segment < PG_DOT_CIRCLE_SEGMENTS; segment++) {
        float angle = (float)segment * (2.0f * (float)M_PI / (float)PG_DOT_CIRCLE_SEGMENTS);
        rim[segment].x = x + cosf(angle) * dotRadiusM;
        rim[segment].y = yOffsetM;
        rim[segment].z = z + sinf(angle) * dotRadiusM;
    }

    uint16_t base = (uint16_t)(dotIndex * PG_DOT_VERTICES_PER_DISC);
    [vertexData appendBytes:&center length:sizeof(center)];
    [vertexData appendBytes:rim length:sizeof(rim)];

    for (int segment = 0; segment < PG_DOT_CIRCLE_SEGMENTS; segment++) {
        uint16_t indices[3] = {
            base,
            (uint16_t)(base + 1 + segment),
            (uint16_t)(base + 1 + ((segment + 1) % PG_DOT_CIRCLE_SEGMENTS))
        };
        [indexData appendBytes:indices length:sizeof(indices)];
    }
}

static SCNGeometry *PGCreateDotGeometryFromBuffers(NSMutableData *vertexData, NSMutableData *indexData, int dotCount) {
    if (dotCount <= 0 || vertexData.length == 0 || indexData.length == 0) {
        return nil;
    }

    SCNGeometrySource *source = [SCNGeometrySource geometrySourceWithData:vertexData
                                                                 semantic:SCNGeometrySourceSemanticVertex
                                                              vectorCount:(NSInteger)dotCount * PG_DOT_VERTICES_PER_DISC
                                                          floatComponents:YES
                                                      componentsPerVector:3
                                                        bytesPerComponent:sizeof(float)
                                                               dataOffset:0
                                                               dataStride:sizeof(PGDotVertex)];
    SCNGeometryElement *element = [SCNGeometryElement geometryElementWithData:indexData
                                                                primitiveType:SCNGeometryPrimitiveTypeTriangles
                                                               primitiveCount:(NSInteger)dotCount * PG_DOT_CIRCLE_SEGMENTS
                                                                bytesPerIndex:sizeof(uint16_t)];
    return [SCNGeometry geometryWithSources:@[source] elements:@[element]];
}

bool pg_anchor_has_polygon_boundary(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    return PGReadPolygonBoundary(anchor, &vertices, &count);
}

bool pg_local_point_in_render_boundary(void *planeAnchor, int boundaryMode, float localX, float localZ) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (boundaryMode == PG_DOT_BOUNDARY_POLYGON) {
        if (!PGReadPolygonBoundary(anchor, &vertices, &count) &&
            !PGReadExtentBoundary(anchor, fallback, &count)) {
            return false;
        }
        if (vertices == NULL) {
            vertices = fallback;
        }
    } else {
        if (!PGReadExtentBoundary(anchor, fallback, &count)) {
            return false;
        }
        vertices = fallback;
    }
    return PGPointInPolygonXZ(localX, localZ, vertices, count);
}

bool pg_local_point_in_polygon(void *planeAnchor, float localX, float localZ) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return false;
    }
    return PGPointInPolygonXZ(localX, localZ, vertices, count);
}

static uint32_t PGSignatureFromVertices(const vector_float3 *vertices, NSUInteger count) {
    uint32_t hash = (uint32_t)count;
    for (NSUInteger i = 0; i < count; i++) {
        hash = hash * 31u + PGHashFloat(vertices[i].x);
        hash = hash * 31u + PGHashFloat(vertices[i].z);
    }
    return hash;
}

uint32_t pg_geometry_signature(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return 0;
    }
    return PGSignatureFromVertices(vertices, count);
}

uint32_t pg_geometry_signature_extent(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    NSUInteger count = 0;
    if (!PGReadExtentBoundary(anchor, fallback, &count)) {
        return 0;
    }
    return PGSignatureFromVertices(fallback, count);
}

static int PGCollectWindowDotPoints(
    ARPlaneAnchor *anchor,
    int boundaryMode,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float *outLocalX,
    float *outLocalZ,
    int maxPoints
) {
    if (anchor == NULL || stepM <= 0.0f || maxPoints <= 0 || outLocalX == NULL || outLocalZ == NULL) {
        return 0;
    }

    vector_float3 extentFallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (boundaryMode == PG_DOT_BOUNDARY_POLYGON) {
        if (!PGReadPolygonBoundary(anchor, &vertices, &count) &&
            !PGReadExtentBoundary(anchor, extentFallback, &count)) {
            return 0;
        }
        if (vertices == NULL) {
            vertices = extentFallback;
        }
    } else {
        if (!PGReadExtentBoundary(anchor, extentFallback, &count)) {
            return 0;
        }
        vertices = extentFallback;
    }

    float minX = INFINITY;
    float maxX = -INFINITY;
    float minZ = INFINITY;
    float maxZ = -INFINITY;
    for (NSUInteger i = 0; i < count; i++) {
        float x = vertices[i].x;
        float z = vertices[i].z;
        if (x < minX) minX = x;
        if (x > maxX) maxX = x;
        if (z < minZ) minZ = z;
        if (z > maxZ) maxZ = z;
    }

    float radiusSq = maxRadiusM * maxRadiusM;
    int written = 0;
    for (float x = floorf(minX / stepM) * stepM; x <= maxX + stepM * 0.5f; x += stepM) {
        for (float z = floorf(minZ / stepM) * stepM; z <= maxZ + stepM * 0.5f; z += stepM) {
            float dx = x - refX;
            float dz = z - refZ;
            if ((dx * dx + dz * dz) > radiusSq) {
                continue;
            }
            if (!PGPointInPolygonXZ(x, z, vertices, count)) {
                continue;
            }
            outLocalX[written] = x;
            outLocalZ[written] = z;
            written++;
            if (written >= maxPoints) {
                return written;
            }
        }
    }
    return written;
}

int pg_generate_dot_points(
    void *planeAnchor,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float *outLocalX,
    float *outLocalZ,
    int maxPoints
) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    if (anchor == NULL || stepM <= 0.0f || maxPoints <= 0 || outLocalX == NULL || outLocalZ == NULL) {
        return 0;
    }

    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return 0;
    }

    float minX = INFINITY;
    float maxX = -INFINITY;
    float minZ = INFINITY;
    float maxZ = -INFINITY;
    for (NSUInteger i = 0; i < count; i++) {
        float x = vertices[i].x;
        float z = vertices[i].z;
        if (x < minX) minX = x;
        if (x > maxX) maxX = x;
        if (z < minZ) minZ = z;
        if (z > maxZ) maxZ = z;
    }

    float radiusSq = maxRadiusM * maxRadiusM;
    int written = 0;
    for (float x = floorf(minX / stepM) * stepM; x <= maxX + stepM * 0.5f; x += stepM) {
        for (float z = floorf(minZ / stepM) * stepM; z <= maxZ + stepM * 0.5f; z += stepM) {
            float dx = x - refX;
            float dz = z - refZ;
            if ((dx * dx + dz * dz) > radiusSq) {
                continue;
            }
            if (!PGPointInPolygonXZ(x, z, vertices, count)) {
                continue;
            }
            outLocalX[written] = x;
            outLocalZ[written] = z;
            written++;
            if (written >= maxPoints) {
                return written;
            }
        }
    }
    return written;
}

int pg_collect_window_dot_points(
    void *planeAnchor,
    int boundaryMode,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float *outLocalX,
    float *outLocalZ,
    int maxPoints
) {
    return PGCollectWindowDotPoints(
        PGCast(planeAnchor),
        boundaryMode,
        stepM,
        refX,
        refZ,
        maxRadiusM,
        outLocalX,
        outLocalZ,
        maxPoints
    );
}

float pg_polygon_area(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return 0.0f;
    }
    return PGPolygonArea(vertices, count);
}

static SCNGeometry *PGCreateDotMeshFromVertices(
    const vector_float3 *vertices,
    NSUInteger count,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float dotRadiusM,
    float yOffsetM,
    int maxPoints,
    int *outDotCount
) {
    if (outDotCount != NULL) {
        *outDotCount = 0;
    }
    if (vertices == NULL || count < 3 || stepM <= 0.0f || maxPoints <= 0 || dotRadiusM <= 0.0f) {
        return nil;
    }

    float minX = INFINITY;
    float maxX = -INFINITY;
    float minZ = INFINITY;
    float maxZ = -INFINITY;
    for (NSUInteger i = 0; i < count; i++) {
        float x = vertices[i].x;
        float z = vertices[i].z;
        if (x < minX) minX = x;
        if (x > maxX) maxX = x;
        if (z < minZ) minZ = z;
        if (z > maxZ) maxZ = z;
    }

    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPoints * PG_DOT_VERTICES_PER_DISC * sizeof(PGDotVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPoints * PG_DOT_CIRCLE_SEGMENTS * 3 * sizeof(uint16_t)];
    float radiusSq = maxRadiusM * maxRadiusM;
    int written = 0;
    for (float x = floorf(minX / stepM) * stepM; x <= maxX + stepM * 0.5f; x += stepM) {
        for (float z = floorf(minZ / stepM) * stepM; z <= maxZ + stepM * 0.5f; z += stepM) {
            float dx = x - refX;
            float dz = z - refZ;
            if ((dx * dx + dz * dz) > radiusSq) {
                continue;
            }
            if (!PGPointInPolygonXZ(x, z, vertices, count)) {
                continue;
            }
            PGWriteDotDisc(vertexData, indexData, written, x, z, dotRadiusM, yOffsetM);
            written++;
            if (written >= maxPoints) {
                if (outDotCount != NULL) {
                    *outDotCount = written;
                }
                return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
            }
        }
    }

    if (outDotCount != NULL) {
        *outDotCount = written;
    }
    return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
}

SCNGeometry *pg_create_dot_mesh_geometry(
    void *planeAnchor,
    int boundaryMode,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float dotRadiusM,
    float yOffsetM,
    int maxPoints,
    int *outDotCount
) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    if (anchor == NULL) {
        if (outDotCount != NULL) {
            *outDotCount = 0;
        }
        return nil;
    }

    vector_float3 extentFallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (boundaryMode == PG_DOT_BOUNDARY_POLYGON) {
        if (!PGReadPolygonBoundary(anchor, &vertices, &count) &&
            !PGReadExtentBoundary(anchor, extentFallback, &count)) {
            if (outDotCount != NULL) {
                *outDotCount = 0;
            }
            return nil;
        }
        if (vertices == NULL) {
            vertices = extentFallback;
        }
    } else {
        if (!PGReadExtentBoundary(anchor, extentFallback, &count)) {
            if (outDotCount != NULL) {
                *outDotCount = 0;
            }
            return nil;
        }
        vertices = extentFallback;
    }

    return PGCreateDotMeshFromVertices(
        vertices,
        count,
        stepM,
        refX,
        refZ,
        maxRadiusM,
        dotRadiusM,
        yOffsetM,
        maxPoints,
        outDotCount
    );
}

SCNGeometry *pg_create_dot_mesh_local_disc(
    float centerX,
    float centerZ,
    float radiusM,
    float stepM,
    float dotRadiusM,
    float yOffsetM,
    int *outDotCount
) {
    if (outDotCount != NULL) {
        *outDotCount = 0;
    }
    if (radiusM <= 0.0f || stepM <= 0.0f || dotRadiusM <= 0.0f) {
        return nil;
    }

    int maxPoints = (int)(((radiusM * 2.0f / stepM) + 2.0f) * ((radiusM * 2.0f / stepM) + 2.0f));
    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPoints * PG_DOT_VERTICES_PER_DISC * sizeof(PGDotVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPoints * PG_DOT_CIRCLE_SEGMENTS * 3 * sizeof(uint16_t)];
    float radiusSq = radiusM * radiusM;
    int written = 0;
    for (float x = -radiusM; x <= radiusM + stepM * 0.5f; x += stepM) {
        for (float z = -radiusM; z <= radiusM + stepM * 0.5f; z += stepM) {
            if ((x * x + z * z) > radiusSq) {
                continue;
            }
            PGWriteDotDisc(vertexData, indexData, written, centerX + x, centerZ + z, dotRadiusM, yOffsetM);
            written++;
        }
    }

    if (outDotCount != NULL) {
        *outDotCount = written;
    }
    return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
}

SCNGeometry *pg_create_dot_mesh_from_points(
    const float *localX,
    const float *localZ,
    int pointCount,
    float dotRadiusM,
    float yOffsetM,
    int *outDotCount
) {
    if (outDotCount != NULL) {
        *outDotCount = 0;
    }
    if (localX == NULL || localZ == NULL || pointCount <= 0 || dotRadiusM <= 0.0f) {
        return nil;
    }

    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)pointCount * PG_DOT_VERTICES_PER_DISC * sizeof(PGDotVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)pointCount * PG_DOT_CIRCLE_SEGMENTS * 3 * sizeof(uint16_t)];
    int written = 0;
    for (int index = 0; index < pointCount; index++) {
        PGWriteDotDisc(vertexData, indexData, written, localX[index], localZ[index], dotRadiusM, yOffsetM);
        written++;
    }

    if (outDotCount != NULL) {
        *outDotCount = written;
    }
    return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
}

SCNGeometry *pg_create_preview_dot_mesh_geometry(
    float radiusM,
    float stepM,
    float dotRadiusM,
    float yOffsetM,
    int *outDotCount
) {
    if (outDotCount != NULL) {
        *outDotCount = 0;
    }
    if (radiusM <= 0.0f || stepM <= 0.0f || dotRadiusM <= 0.0f) {
        return nil;
    }

    int maxPreviewPoints = (int)(((radiusM * 2.0f / stepM) + 2.0f) * ((radiusM * 2.0f / stepM) + 2.0f));
    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPreviewPoints * PG_DOT_VERTICES_PER_DISC * sizeof(PGDotVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPreviewPoints * PG_DOT_CIRCLE_SEGMENTS * 3 * sizeof(uint16_t)];
    float radiusSq = radiusM * radiusM;
    int written = 0;
    for (float x = -radiusM; x <= radiusM + stepM * 0.5f; x += stepM) {
        for (float z = -radiusM; z <= radiusM + stepM * 0.5f; z += stepM) {
            if ((x * x + z * z) > radiusSq) {
                continue;
            }
            PGWriteDotDisc(vertexData, indexData, written, x, z, dotRadiusM, yOffsetM);
            written++;
        }
    }

    if (outDotCount != NULL) {
        *outDotCount = written;
    }
    return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
}

bool pg_plane_extent_dimensions(
    void *planeAnchor,
    float *outWidth,
    float *outHeight,
    float *outCenterX,
    float *outCenterZ
) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    if (anchor == NULL || outWidth == NULL || outHeight == NULL || outCenterX == NULL || outCenterZ == NULL) {
        return NO;
    }

    float width = 0.0f;
    float depth = 0.0f;
    float centerX = 0.0f;
    float centerZ = 0.0f;

    if (@available(iOS 16.0, *)) {
        width = anchor.planeExtent.width;
        depth = anchor.planeExtent.height;
    } else {
#pragma clang diagnostic push
#pragma clang diagnostic ignored "-Wdeprecated-declarations"
        width = anchor.extent.x;
        depth = anchor.extent.z;
#pragma clang diagnostic pop
    }
    // Center offset is on ARPlaneAnchor, not ARPlaneExtent (width/height only on extent).
    centerX = anchor.center.x;
    centerZ = anchor.center.z;

    if (width <= 0.0f || depth <= 0.0f) {
        return NO;
    }

    *outWidth = width;
    *outHeight = depth;
    *outCenterX = centerX;
    *outCenterZ = centerZ;
    return YES;
}

float pg_plane_extent_area(void *planeAnchor) {
    float width = 0.0f;
    float depth = 0.0f;
    float centerX = 0.0f;
    float centerZ = 0.0f;
    if (!pg_plane_extent_dimensions(planeAnchor, &width, &depth, &centerX, &centerZ)) {
        return 0.0f;
    }
    return width * depth;
}

static ARAnchor *PGAnchorCast(void *anchorPtr) {
    if (anchorPtr == NULL) {
        return NULL;
    }
    return (__bridge ARAnchor *)anchorPtr;
}

bool pg_world_xz_on_anchor(
    void *anchorPtr,
    float worldX,
    float worldY,
    float worldZ,
    float *outLocalX,
    float *outLocalZ
) {
    ARAnchor *anchor = PGAnchorCast(anchorPtr);
    if (anchor == NULL || outLocalX == NULL || outLocalZ == NULL) {
        return false;
    }
    simd_float4x4 transform = anchor.transform;
    simd_float4x4 inverse = simd_inverse(transform);
    simd_float4 world = simd_make_float4(worldX, worldY, worldZ, 1.0f);
    simd_float4 local = simd_mul(inverse, world);
    *outLocalX = local.x;
    *outLocalZ = local.z;
    return true;
}

bool pg_local_xz_to_world(
    void *anchorPtr,
    float localX,
    float localY,
    float localZ,
    float *outWorldX,
    float *outWorldY,
    float *outWorldZ
) {
    ARAnchor *anchor = PGAnchorCast(anchorPtr);
    if (anchor == NULL || outWorldX == NULL || outWorldY == NULL || outWorldZ == NULL) {
        return false;
    }
    simd_float4x4 transform = anchor.transform;
    simd_float4 local = simd_make_float4(localX, localY, localZ, 1.0f);
    simd_float4 world = simd_mul(transform, local);
    *outWorldX = world.x;
    *outWorldY = world.y;
    *outWorldZ = world.z;
    return true;
}

#define PG_MAX_GRID_LINES_PER_AXIS 52
#define PG_MAX_CONTOUR_SEGMENTS 1024

typedef struct {
    float x;
    float y;
    float z;
} PGGridVertex;

static void PGGridAppendQuad(
    NSMutableData *vertexData,
    NSMutableData *indexData,
    uint16_t *baseIndex,
    float x0,
    float z0,
    float x1,
    float z1,
    float x2,
    float z2,
    float x3,
    float z3,
    float y
) {
    PGGridVertex verts[4] = {
        { x0, y, z0 },
        { x1, y, z1 },
        { x2, y, z2 },
        { x3, y, z3 }
    };
    uint16_t base = *baseIndex;
    [vertexData appendBytes:verts length:sizeof(verts)];
    uint16_t indices[6] = {
        base,
        (uint16_t)(base + 1u),
        (uint16_t)(base + 2u),
        base,
        (uint16_t)(base + 2u),
        (uint16_t)(base + 3u)
    };
    [indexData appendBytes:indices length:sizeof(indices)];
    *baseIndex = (uint16_t)(base + 4u);
}

SCNGeometry *pg_create_contour_lines_geometry(
    int segmentCount,
    const float *segmentPairsXZ,
    float yM,
    float halfWidthM
) {
    if (segmentCount <= 0 || segmentPairsXZ == NULL || halfWidthM <= 0.0f) {
        return nil;
    }
    if (segmentCount > PG_MAX_CONTOUR_SEGMENTS) {
        segmentCount = PG_MAX_CONTOUR_SEGMENTS;
    }

    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)segmentCount * 4 * sizeof(PGGridVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)segmentCount * 6 * sizeof(uint16_t)];
    uint16_t vertexIndex = 0;

    for (int i = 0; i < segmentCount; i++) {
        float sx = segmentPairsXZ[i * 4 + 0];
        float sz = segmentPairsXZ[i * 4 + 1];
        float ex = segmentPairsXZ[i * 4 + 2];
        float ez = segmentPairsXZ[i * 4 + 3];
        float dx = ex - sx;
        float dz = ez - sz;
        float lenSq = dx * dx + dz * dz;
        if (lenSq < 1e-6f) {
            continue;
        }
        float len = sqrtf(lenSq);
        float ux = dx / len;
        float uz = dz / len;
        float px = -uz * halfWidthM;
        float pz = ux * halfWidthM;
        PGGridAppendQuad(
            vertexData,
            indexData,
            &vertexIndex,
            sx - px,
            sz - pz,
            sx + px,
            sz + pz,
            ex + px,
            ez + pz,
            ex - px,
            ez - pz,
            yM
        );
    }

    if (vertexIndex == 0) {
        return nil;
    }

    NSInteger vertexCount = (NSInteger)vertexIndex;
    NSInteger primitiveCount = vertexCount / 2;
    SCNGeometrySource *source = [SCNGeometrySource geometrySourceWithData:vertexData
                                                                 semantic:SCNGeometrySourceSemanticVertex
                                                              vectorCount:vertexCount
                                                          floatComponents:YES
                                                      componentsPerVector:3
                                                        bytesPerComponent:sizeof(float)
                                                               dataOffset:0
                                                               dataStride:sizeof(PGGridVertex)];
    SCNGeometryElement *element = [SCNGeometryElement geometryElementWithData:indexData
                                                                primitiveType:SCNGeometryPrimitiveTypeTriangles
                                                               primitiveCount:primitiveCount
                                                                bytesPerIndex:sizeof(uint16_t)];
    return [SCNGeometry geometryWithSources:@[source] elements:@[element]];
}

static SCNMaterial *PGCreateContourFillMaterial(void) {
    SCNMaterial *material = [SCNMaterial material];
    material.diffuse.contents = [UIColor colorWithRed:0.18f green:0.62f blue:0.98f alpha:0.58f];
    material.lightingModelName = SCNLightingModelConstant;
    material.doubleSided = YES;
    material.readsFromDepthBuffer = YES;
    material.writesToDepthBuffer = NO;
    material.transparencyMode = SCNTransparencyModeAOne;
    return material;
}

SCNGeometry *pg_create_contour_fill_geometry(
    int pointCount,
    const float *pointsXZ,
    float yM
) {
    if (pointCount < 3 || pointsXZ == NULL) {
        return nil;
    }
    if (pointCount > PG_MAX_CONTOUR_FILL_POINTS) {
        pointCount = PG_MAX_CONTOUR_FILL_POINTS;
    }

    float centroidX = 0.0f;
    float centroidZ = 0.0f;
    for (int i = 0; i < pointCount; i++) {
        centroidX += pointsXZ[i * 2 + 0];
        centroidZ += pointsXZ[i * 2 + 1];
    }
    centroidX /= (float)pointCount;
    centroidZ /= (float)pointCount;

    NSInteger vertexCount = pointCount + 1;
    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)vertexCount * sizeof(PGGridVertex)];
    PGGridVertex centroidVertex = {centroidX, yM, centroidZ};
    [vertexData appendBytes:&centroidVertex length:sizeof(centroidVertex)];
    for (int i = 0; i < pointCount; i++) {
        PGGridVertex vertex = {pointsXZ[i * 2 + 0], yM, pointsXZ[i * 2 + 1]};
        [vertexData appendBytes:&vertex length:sizeof(vertex)];
    }

    float minX = pointsXZ[0];
    float maxX = pointsXZ[0];
    float minZ = pointsXZ[1];
    float maxZ = pointsXZ[1];
    for (int i = 1; i < pointCount; i++) {
        float x = pointsXZ[i * 2 + 0];
        float z = pointsXZ[i * 2 + 1];
        if (x < minX) minX = x;
        if (x > maxX) maxX = x;
        if (z < minZ) minZ = z;
        if (z > maxZ) maxZ = z;
    }
    float spanX = maxX - minX;
    float spanZ = maxZ - minZ;
    if (spanX < 0.001f) spanX = 0.001f;
    if (spanZ < 0.001f) spanZ = 0.001f;

    NSMutableData *texcoordData = [NSMutableData dataWithCapacity:(NSUInteger)vertexCount * 2 * sizeof(float)];
    float centroidU = (centroidX - minX) / spanX;
    float centroidV = (centroidZ - minZ) / spanZ;
    float centroidUv[2] = {centroidU, centroidV};
    [texcoordData appendBytes:centroidUv length:sizeof(centroidUv)];
    for (int i = 0; i < pointCount; i++) {
        float x = pointsXZ[i * 2 + 0];
        float z = pointsXZ[i * 2 + 1];
        float uv[2] = {(x - minX) / spanX, (z - minZ) / spanZ};
        [texcoordData appendBytes:uv length:sizeof(uv)];
    }

    NSInteger triangleCount = pointCount * 2;
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)triangleCount * 3 * sizeof(uint16_t)];
    for (int i = 0; i < pointCount; i++) {
        int next = (i + 1) % pointCount;
        uint16_t forward[3] = {
            0,
            (uint16_t)(i + 1),
            (uint16_t)(next + 1)
        };
        uint16_t reversed[3] = {
            0,
            (uint16_t)(next + 1),
            (uint16_t)(i + 1)
        };
        [indexData appendBytes:forward length:sizeof(forward)];
        [indexData appendBytes:reversed length:sizeof(reversed)];
    }

    SCNGeometrySource *source = [SCNGeometrySource geometrySourceWithData:vertexData
                                                                 semantic:SCNGeometrySourceSemanticVertex
                                                              vectorCount:vertexCount
                                                          floatComponents:YES
                                                      componentsPerVector:3
                                                        bytesPerComponent:sizeof(float)
                                                               dataOffset:0
                                                               dataStride:sizeof(PGGridVertex)];
    SCNGeometrySource *texSource = [SCNGeometrySource geometrySourceWithData:texcoordData
                                                                    semantic:SCNGeometrySourceSemanticTexcoord
                                                                 vectorCount:vertexCount
                                                             floatComponents:YES
                                                         componentsPerVector:2
                                                           bytesPerComponent:sizeof(float)
                                                                  dataOffset:0
                                                                  dataStride:2 * sizeof(float)];
    SCNGeometryElement *element = [SCNGeometryElement geometryElementWithData:indexData
                                                                primitiveType:SCNGeometryPrimitiveTypeTriangles
                                                               primitiveCount:triangleCount
                                                                bytesPerIndex:sizeof(uint16_t)];
    SCNGeometry *geometry = [SCNGeometry geometryWithSources:@[source, texSource] elements:@[element]];
    geometry.materials = @[PGCreateContourFillMaterial()];
    return geometry;
}

SCNGeometry *pg_create_grid_line_geometry(
    float widthM,
    float depthM,
    float centerX,
    float centerZ,
    float cellM,
    float lineWidthM,
    float yM
) {
    if (widthM <= 0.0f || depthM <= 0.0f || cellM <= 0.0f || lineWidthM <= 0.0f) {
        return nil;
    }

    float halfW = widthM * 0.5f;
    float halfD = depthM * 0.5f;
    float halfLine = lineWidthM * 0.5f;
    float xMin = centerX - halfW;
    float xMax = centerX + halfW;
    float zMin = centerZ - halfD;
    float zMax = centerZ + halfD;

    int hCount = (int)floorf(depthM / cellM) + 1;
    int vCount = (int)floorf(widthM / cellM) + 1;
    if (hCount > PG_MAX_GRID_LINES_PER_AXIS) {
        hCount = PG_MAX_GRID_LINES_PER_AXIS;
    }
    if (vCount > PG_MAX_GRID_LINES_PER_AXIS) {
        vCount = PG_MAX_GRID_LINES_PER_AXIS;
    }
    if (hCount < 1) {
        hCount = 1;
    }
    if (vCount < 1) {
        vCount = 1;
    }

    int quadCount = hCount + vCount;
    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)quadCount * 4 * sizeof(PGGridVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)quadCount * 6 * sizeof(uint16_t)];
    uint16_t vertexIndex = 0;

    for (int i = 0; i < hCount; i++) {
        float t = (hCount == 1) ? 0.5f : ((float)i / (float)(hCount - 1));
        float z = zMin + t * (zMax - zMin);
        PGGridAppendQuad(
            vertexData,
            indexData,
            &vertexIndex,
            xMin,
            z - halfLine,
            xMax,
            z - halfLine,
            xMax,
            z + halfLine,
            xMin,
            z + halfLine,
            yM
        );
    }

    for (int i = 0; i < vCount; i++) {
        float t = (vCount == 1) ? 0.5f : ((float)i / (float)(vCount - 1));
        float x = xMin + t * (xMax - xMin);
        PGGridAppendQuad(
            vertexData,
            indexData,
            &vertexIndex,
            x - halfLine,
            zMin,
            x + halfLine,
            zMin,
            x + halfLine,
            zMax,
            x - halfLine,
            zMax,
            yM
        );
    }

    if (vertexIndex == 0) {
        return nil;
    }

    NSInteger vertexCount = (NSInteger)vertexIndex;
    NSInteger primitiveCount = (NSInteger)quadCount * 2;
    SCNGeometrySource *source = [SCNGeometrySource geometrySourceWithData:vertexData
                                                                 semantic:SCNGeometrySourceSemanticVertex
                                                              vectorCount:vertexCount
                                                          floatComponents:YES
                                                      componentsPerVector:3
                                                        bytesPerComponent:sizeof(float)
                                                               dataOffset:0
                                                               dataStride:sizeof(PGGridVertex)];
    SCNGeometryElement *element = [SCNGeometryElement geometryElementWithData:indexData
                                                                primitiveType:SCNGeometryPrimitiveTypeTriangles
                                                               primitiveCount:primitiveCount
                                                                bytesPerIndex:sizeof(uint16_t)];
    return [SCNGeometry geometryWithSources:@[source] elements:@[element]];
}

static int PGCompareFloat(const void *a, const void *b) {
    float fa = *(const float *)a;
    float fb = *(const float *)b;
    if (fa < fb) {
        return -1;
    }
    if (fa > fb) {
        return 1;
    }
    return 0;
}

static void PGGridAppendEdgeQuad(
    NSMutableData *vertexData,
    NSMutableData *indexData,
    uint16_t *baseIndex,
    float x1,
    float z1,
    float x2,
    float z2,
    float halfWidth,
    float y
) {
    float dx = x2 - x1;
    float dz = z2 - z1;
    float len = sqrtf(dx * dx + dz * dz);
    if (len < 1e-5f) {
        return;
    }
    float nx = (-dz / len) * halfWidth;
    float nz = (dx / len) * halfWidth;
    PGGridAppendQuad(
        vertexData,
        indexData,
        baseIndex,
        x1 + nx,
        z1 + nz,
        x2 + nx,
        z2 + nz,
        x2 - nx,
        z2 - nz,
        x1 - nx,
        z1 - nz,
        y
    );
}

#define PG_MAX_POLYGON_INTERSECTIONS 32

int pg_copy_plane_boundary_xz(
    void *planeAnchor,
    float *outLocalX,
    float *outLocalZ,
    int maxVertices
) {
    if (planeAnchor == NULL || outLocalX == NULL || outLocalZ == NULL || maxVertices <= 0) {
        return 0;
    }
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return 0;
    }
    if (count > (NSUInteger)maxVertices) {
        count = (NSUInteger)maxVertices;
    }
    for (NSUInteger i = 0; i < count; i++) {
        outLocalX[i] = vertices[i].x;
        outLocalZ[i] = vertices[i].z;
    }
    return (int)count;
}

static int PGCollectIntersectionsAtZ(
    float z,
    const vector_float3 *vertices,
    NSUInteger count,
    float *outX,
    int maxOut
) {
    int written = 0;
    for (NSUInteger i = 0; i < count; i++) {
        NSUInteger next = (i + 1u) % count;
        float x1 = vertices[i].x;
        float z1 = vertices[i].z;
        float x2 = vertices[next].x;
        float z2 = vertices[next].z;
        if (fabsf(z2 - z1) < 1e-5f) {
            continue;
        }
        float zMin = fminf(z1, z2);
        float zMax = fmaxf(z1, z2);
        if (z < zMin - 1e-4f || z > zMax + 1e-4f) {
            continue;
        }
        float t = (z - z1) / (z2 - z1);
        float x = x1 + t * (x2 - x1);
        if (written < maxOut) {
            outX[written++] = x;
        }
    }
    if (written > 1) {
        qsort(outX, (size_t)written, sizeof(float), PGCompareFloat);
    }
    return written;
}

static int PGCollectIntersectionsAtX(
    float x,
    const vector_float3 *vertices,
    NSUInteger count,
    float *outZ,
    int maxOut
) {
    int written = 0;
    for (NSUInteger i = 0; i < count; i++) {
        NSUInteger next = (i + 1u) % count;
        float x1 = vertices[i].x;
        float z1 = vertices[i].z;
        float x2 = vertices[next].x;
        float z2 = vertices[next].z;
        if (fabsf(x2 - x1) < 1e-5f) {
            continue;
        }
        float xMin = fminf(x1, x2);
        float xMax = fmaxf(x1, x2);
        if (x < xMin - 1e-4f || x > xMax + 1e-4f) {
            continue;
        }
        float t = (x - x1) / (x2 - x1);
        float z = z1 + t * (z2 - z1);
        if (written < maxOut) {
            outZ[written++] = z;
        }
    }
    if (written > 1) {
        qsort(outZ, (size_t)written, sizeof(float), PGCompareFloat);
    }
    return written;
}

static void PGAppendHorizontalGridInPolygon(
    NSMutableData *vertexData,
    NSMutableData *indexData,
    uint16_t *vertexIndex,
    const vector_float3 *vertices,
    NSUInteger count,
    float z,
    float halfLine,
    float yM
) {
    float intersections[PG_MAX_POLYGON_INTERSECTIONS];
    int intersectionCount = PGCollectIntersectionsAtZ(z, vertices, count, intersections, PG_MAX_POLYGON_INTERSECTIONS);
    for (int i = 0; i + 1 < intersectionCount; i += 2) {
        float x0 = intersections[i];
        float x1 = intersections[i + 1];
        if ((x1 - x0) <= 1e-4f) {
            continue;
        }
        PGGridAppendQuad(
            vertexData,
            indexData,
            vertexIndex,
            x0,
            z - halfLine,
            x1,
            z - halfLine,
            x1,
            z + halfLine,
            x0,
            z + halfLine,
            yM
        );
    }
}

static void PGAppendVerticalGridInPolygon(
    NSMutableData *vertexData,
    NSMutableData *indexData,
    uint16_t *vertexIndex,
    const vector_float3 *vertices,
    NSUInteger count,
    float x,
    float halfLine,
    float yM
) {
    float intersections[PG_MAX_POLYGON_INTERSECTIONS];
    int intersectionCount = PGCollectIntersectionsAtX(x, vertices, count, intersections, PG_MAX_POLYGON_INTERSECTIONS);
    for (int i = 0; i + 1 < intersectionCount; i += 2) {
        float z0 = intersections[i];
        float z1 = intersections[i + 1];
        if ((z1 - z0) <= 1e-4f) {
            continue;
        }
        PGGridAppendQuad(
            vertexData,
            indexData,
            vertexIndex,
            x - halfLine,
            z0,
            x + halfLine,
            z0,
            x + halfLine,
            z1,
            x - halfLine,
            z1,
            yM
        );
    }
}

static SCNGeometry *PGCreatePolygonGridFromVertices(
    const float *localX,
    const float *localZ,
    NSUInteger count,
    float cellM,
    float lineWidthM,
    float boundaryLineWidthM,
    float yM
) {
    if (localX == NULL || localZ == NULL || count < 3u || cellM <= 0.0f || lineWidthM <= 0.0f) {
        return nil;
    }
    if (count > PG_MAX_BOUNDARY_VERTICES) {
        count = PG_MAX_BOUNDARY_VERTICES;
    }

    vector_float3 vertices[PG_MAX_BOUNDARY_VERTICES];
    for (NSUInteger i = 0; i < count; i++) {
        vertices[i] = (vector_float3){ localX[i], 0.0f, localZ[i] };
    }

    float minX = INFINITY;
    float maxX = -INFINITY;
    float minZ = INFINITY;
    float maxZ = -INFINITY;
    for (NSUInteger i = 0; i < count; i++) {
        float x = vertices[i].x;
        float z = vertices[i].z;
        if (x < minX) {
            minX = x;
        }
        if (x > maxX) {
            maxX = x;
        }
        if (z < minZ) {
            minZ = z;
        }
        if (z > maxZ) {
            maxZ = z;
        }
    }

    float halfLine = lineWidthM * 0.5f;
    float depthM = maxZ - minZ;
    float widthM = maxX - minX;
    if (depthM <= 0.0f || widthM <= 0.0f) {
        return nil;
    }

    int hCount = (int)floorf(depthM / cellM) + 1;
    int vCount = (int)floorf(widthM / cellM) + 1;
    if (hCount > PG_MAX_GRID_LINES_PER_AXIS) {
        hCount = PG_MAX_GRID_LINES_PER_AXIS;
    }
    if (vCount > PG_MAX_GRID_LINES_PER_AXIS) {
        vCount = PG_MAX_GRID_LINES_PER_AXIS;
    }
    if (hCount < 1) {
        hCount = 1;
    }
    if (vCount < 1) {
        vCount = 1;
    }

    int estimatedQuads = hCount + vCount + (boundaryLineWidthM > 0.0f ? (int)count : 0);
    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)estimatedQuads * 8u * sizeof(PGGridVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)estimatedQuads * 12u * sizeof(uint16_t)];
    uint16_t vertexIndex = 0;

    if (boundaryLineWidthM > 0.0f) {
        float halfBoundary = boundaryLineWidthM * 0.5f;
        for (NSUInteger i = 0; i < count; i++) {
            NSUInteger next = (i + 1u) % count;
            PGGridAppendEdgeQuad(
                vertexData,
                indexData,
                &vertexIndex,
                vertices[i].x,
                vertices[i].z,
                vertices[next].x,
                vertices[next].z,
                halfBoundary,
                yM
            );
        }
    }

    for (int i = 0; i < hCount; i++) {
        float t = (hCount == 1) ? 0.5f : ((float)i / (float)(hCount - 1));
        float z = minZ + t * (maxZ - minZ);
        PGAppendHorizontalGridInPolygon(vertexData, indexData, &vertexIndex, vertices, count, z, halfLine, yM);
    }

    for (int i = 0; i < vCount; i++) {
        float t = (vCount == 1) ? 0.5f : ((float)i / (float)(vCount - 1));
        float x = minX + t * (maxX - minX);
        PGAppendVerticalGridInPolygon(vertexData, indexData, &vertexIndex, vertices, count, x, halfLine, yM);
    }

    if (vertexIndex == 0) {
        return nil;
    }

    SCNGeometrySource *source = [SCNGeometrySource geometrySourceWithData:vertexData
                                                                 semantic:SCNGeometrySourceSemanticVertex
                                                              vectorCount:(NSInteger)vertexIndex
                                                          floatComponents:YES
                                                      componentsPerVector:3
                                                        bytesPerComponent:sizeof(float)
                                                               dataOffset:0
                                                               dataStride:sizeof(PGGridVertex)];
    SCNGeometryElement *element = [SCNGeometryElement geometryElementWithData:indexData
                                                                primitiveType:SCNGeometryPrimitiveTypeTriangles
                                                               primitiveCount:(NSInteger)indexData.length / (sizeof(uint16_t) * 3u)
                                                                bytesPerIndex:sizeof(uint16_t)];
    return [SCNGeometry geometryWithSources:@[source] elements:@[element]];
}

SCNGeometry *pg_create_polygon_grid_line_geometry_from_vertices(
    const float *localX,
    const float *localZ,
    int vertexCount,
    float cellM,
    float lineWidthM,
    float boundaryLineWidthM,
    float yM
) {
    if (vertexCount < 3) {
        return nil;
    }
    return PGCreatePolygonGridFromVertices(
        localX,
        localZ,
        (NSUInteger)vertexCount,
        cellM,
        lineWidthM,
        boundaryLineWidthM,
        yM
    );
}

SCNGeometry *pg_create_world_aligned_placement_patch_grid_geometry(
    float patchSizeM,
    float worldCenterX,
    float worldCenterZ,
    float cellM,
    float lineWidthM,
    float boundaryLineWidthM,
    float yM
) {
    if (patchSizeM <= 0.0f || cellM <= 0.0f || lineWidthM <= 0.0f) {
        return nil;
    }

    float half = patchSizeM * 0.5f;
    float halfLine = lineWidthM * 0.5f;
    float worldMinX = worldCenterX - half;
    float worldMaxX = worldCenterX + half;
    float worldMinZ = worldCenterZ - half;
    float worldMaxZ = worldCenterZ + half;

    int maxLines = (int)floorf(patchSizeM / cellM) + 4;
    if (maxLines > PG_MAX_GRID_LINES_PER_AXIS) {
        maxLines = PG_MAX_GRID_LINES_PER_AXIS;
    }
    int estimatedQuads = maxLines * 2 + 4;
    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)estimatedQuads * 4 * sizeof(PGGridVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)estimatedQuads * 6 * sizeof(uint16_t)];
    uint16_t vertexIndex = 0;

    if (boundaryLineWidthM > 0.0f) {
        float halfBoundary = boundaryLineWidthM * 0.5f;
        PGGridAppendEdgeQuad(vertexData, indexData, &vertexIndex, -half, -half, half, -half, halfBoundary, yM);
        PGGridAppendEdgeQuad(vertexData, indexData, &vertexIndex, half, -half, half, half, halfBoundary, yM);
        PGGridAppendEdgeQuad(vertexData, indexData, &vertexIndex, half, half, -half, half, halfBoundary, yM);
        PGGridAppendEdgeQuad(vertexData, indexData, &vertexIndex, -half, half, -half, -half, halfBoundary, yM);
    }

    float firstWorldZ = ceilf((worldMinZ - 1e-5f) / cellM) * cellM;
    for (float worldZ = firstWorldZ; worldZ <= worldMaxZ + 1e-5f; worldZ += cellM) {
        float localZ = worldZ - worldCenterZ;
        if (localZ < -half - halfLine || localZ > half + halfLine) {
            continue;
        }
        PGGridAppendQuad(
            vertexData,
            indexData,
            &vertexIndex,
            -half,
            localZ - halfLine,
            half,
            localZ - halfLine,
            half,
            localZ + halfLine,
            -half,
            localZ + halfLine,
            yM
        );
    }

    float firstWorldX = ceilf((worldMinX - 1e-5f) / cellM) * cellM;
    for (float worldX = firstWorldX; worldX <= worldMaxX + 1e-5f; worldX += cellM) {
        float localX = worldX - worldCenterX;
        if (localX < -half - halfLine || localX > half + halfLine) {
            continue;
        }
        PGGridAppendQuad(
            vertexData,
            indexData,
            &vertexIndex,
            localX - halfLine,
            -half,
            localX + halfLine,
            -half,
            localX + halfLine,
            half,
            localX - halfLine,
            half,
            yM
        );
    }

    if (vertexIndex == 0) {
        return nil;
    }

    SCNGeometrySource *source = [SCNGeometrySource geometrySourceWithData:vertexData
                                                                 semantic:SCNGeometrySourceSemanticVertex
                                                              vectorCount:(NSInteger)vertexIndex
                                                          floatComponents:YES
                                                      componentsPerVector:3
                                                        bytesPerComponent:sizeof(float)
                                                               dataOffset:0
                                                               dataStride:sizeof(PGGridVertex)];
    SCNGeometryElement *element = [SCNGeometryElement geometryElementWithData:indexData
                                                                primitiveType:SCNGeometryPrimitiveTypeTriangles
                                                               primitiveCount:(NSInteger)indexData.length / (sizeof(uint16_t) * 3u)
                                                                bytesPerIndex:sizeof(uint16_t)];
    return [SCNGeometry geometryWithSources:@[source] elements:@[element]];
}

SCNGeometry *pg_create_polygon_grid_line_geometry(
    void *planeAnchor,
    float cellM,
    float lineWidthM,
    float boundaryLineWidthM,
    float yM
) {
    float localX[PG_MAX_BOUNDARY_VERTICES];
    float localZ[PG_MAX_BOUNDARY_VERTICES];
    int count = pg_copy_plane_boundary_xz(planeAnchor, localX, localZ, PG_MAX_BOUNDARY_VERTICES);
    if (count < 3) {
        return nil;
    }
    return PGCreatePolygonGridFromVertices(
        localX,
        localZ,
        (NSUInteger)count,
        cellM,
        lineWidthM,
        boundaryLineWidthM,
        yM
    );
}

static UIImage *PGGridPatternImageWithLineWidth(CGFloat lineWidth) {
    const CGFloat tile = 64.0;
    UIGraphicsBeginImageContextWithOptions(CGSizeMake(tile, tile), NO, 0.0);
    CGContextRef ctx = UIGraphicsGetCurrentContext();
    UIImage *image = nil;
    if (ctx != NULL) {
        /* Transparent background — only stroke lines, no fill. */
        CGContextClearRect(ctx, CGRectMake(0.0, 0.0, tile, tile));
        CGContextSetStrokeColorWithColor(ctx, [UIColor colorWithWhite:1.0 alpha:1.0].CGColor);
        CGContextSetLineWidth(ctx, lineWidth);
        CGContextSetLineCap(ctx, kCGLineCapSquare);
        const CGFloat half = lineWidth * 0.5;
        CGContextMoveToPoint(ctx, half, 0.0);
        CGContextAddLineToPoint(ctx, half, tile);
        CGContextMoveToPoint(ctx, 0.0, half);
        CGContextAddLineToPoint(ctx, tile, half);
        CGContextStrokePath(ctx);
        image = UIGraphicsGetImageFromCurrentImageContext();
    }
    UIGraphicsEndImageContext();
    return image;
}

static UIImage *PGGridPatternImage(void) {
    static UIImage *cached = nil;
    if (cached == nil) {
        cached = PGGridPatternImageWithLineWidth(3.0);
    }
    return cached;
}

static UIImage *PGGridPatternImageOutdoor(void) {
    static UIImage *cached = nil;
    if (cached == nil) {
        cached = PGGridPatternImageWithLineWidth(4.5);
    }
    return cached;
}

UIImage *pg_grid_pattern_image(void) {
    return PGGridPatternImage();
}

UIImage *pg_grid_pattern_image_outdoor(void) {
    return PGGridPatternImageOutdoor();
}

UIImage *pg_create_contour_distance_label_image(const char *text) {
    if (text == NULL) {
        return nil;
    }
    NSString *label = [NSString stringWithUTF8String:text];
    if (label.length == 0) {
        return nil;
    }
    const CGFloat width = 320.0;
    const CGFloat height = 112.0;
    UIGraphicsBeginImageContextWithOptions(CGSizeMake(width, height), NO, 0.0);
    CGContextRef ctx = UIGraphicsGetCurrentContext();
    UIImage *image = nil;
    if (ctx != NULL) {
        CGContextSetFillColorWithColor(ctx, [UIColor colorWithWhite:1.0 alpha:1.0].CGColor);
        CGRect bounds = CGRectMake(0.0, 0.0, width, height);
        CGContextAddPath(ctx, [UIBezierPath bezierPathWithRoundedRect:bounds cornerRadius:28.0].CGPath);
        CGContextFillPath(ctx);

        NSMutableParagraphStyle *style = [[NSMutableParagraphStyle alloc] init];
        style.alignment = NSTextAlignmentCenter;
        NSDictionary *attrs = @{
            NSFontAttributeName: [UIFont boldSystemFontOfSize:38.0],
            NSForegroundColorAttributeName: [UIColor blackColor],
            NSParagraphStyleAttributeName: style
        };
        CGSize textSize = [label sizeWithAttributes:attrs];
        CGRect textRect = CGRectMake(
            (width - textSize.width) * 0.5,
            (height - textSize.height) * 0.5,
            textSize.width,
            textSize.height
        );
        [label drawInRect:textRect withAttributes:attrs];
        image = UIGraphicsGetImageFromCurrentImageContext();
    }
    UIGraphicsEndImageContext();
    return image;
}

static UIImage *PGRotatedImage(UIImage *source, CGFloat degrees) {
    if (source == nil || fabs(degrees) < 0.01f) {
        return source;
    }
    CGFloat radians = degrees * (CGFloat)M_PI / 180.0;
    CGRect bounds = CGRectMake(0.0, 0.0, source.size.width, source.size.height);
    UIGraphicsBeginImageContextWithOptions(bounds.size, NO, source.scale);
    CGContextRef ctx = UIGraphicsGetCurrentContext();
    UIImage *image = nil;
    if (ctx != NULL) {
        CGContextTranslateCTM(ctx, bounds.size.width * 0.5, bounds.size.height * 0.5);
        CGContextRotateCTM(ctx, radians);
        [source drawInRect:CGRectMake(
            -bounds.size.width * 0.5,
            -bounds.size.height * 0.5,
            bounds.size.width,
            bounds.size.height
        )];
        image = UIGraphicsGetImageFromCurrentImageContext();
    }
    UIGraphicsEndImageContext();
    return image ?: source;
}

static UIImage *PGLoadTileTextureSource(const char *resourceName) {
    if (resourceName == NULL) {
        return nil;
    }
    NSString *stem = [NSString stringWithUTF8String:resourceName];
    if (stem.length == 0) {
        return nil;
    }
    NSBundle *bundle = [NSBundle mainBundle];
    UIImage *image = [UIImage imageNamed:stem];
    if (image != nil) {
        return image;
    }
    image = [UIImage imageNamed:[NSString stringWithFormat:@"%@.png", stem]];
    if (image != nil) {
        return image;
    }
    NSString *withFolder = [NSString stringWithFormat:@"mock/tiles/textures/%@", stem];
    image = [UIImage imageNamed:withFolder];
    if (image != nil) {
        return image;
    }
    image = [UIImage imageNamed:[NSString stringWithFormat:@"mock/tiles/textures/%@.png", stem]];
    if (image != nil) {
        return image;
    }
    NSString *path = [bundle pathForResource:stem ofType:@"png" inDirectory:@"mock/tiles/textures"];
    if (path.length > 0) {
        image = [UIImage imageWithContentsOfFile:path];
        if (image != nil) {
            return image;
        }
    }
    path = [bundle pathForResource:stem ofType:@"png"];
    if (path.length > 0) {
        return [UIImage imageWithContentsOfFile:path];
    }
    return nil;
}

static const CGFloat PG_TILE_TEXTURE_WIDTH_M = 0.78f;
static const CGFloat PG_TILE_TEXTURE_HEIGHT_M = 1.04f;
static const int PG_MIN_SECTION_TEXTURE_PX = 64;
static const int PG_MAX_SECTION_TEXTURE_PX = 2048;

UIImage *pg_create_tile_section_pattern_image(
    const char *resourceName,
    float widthMeters,
    float heightMeters,
    float rotationDegrees
) {
    UIImage *source = PGLoadTileTextureSource(resourceName);
    if (source == nil || widthMeters <= 0.0f || heightMeters <= 0.0f) {
        return nil;
    }
    CGFloat srcW = source.size.width;
    CGFloat srcH = source.size.height;
    if (srcW <= 1.0 || srcH <= 1.0) {
        return nil;
    }

    int outW = (int)((srcW / PG_TILE_TEXTURE_WIDTH_M) * widthMeters);
    int outH = (int)((srcH / PG_TILE_TEXTURE_HEIGHT_M) * heightMeters);
    if (outW < PG_MIN_SECTION_TEXTURE_PX) outW = PG_MIN_SECTION_TEXTURE_PX;
    if (outH < PG_MIN_SECTION_TEXTURE_PX) outH = PG_MIN_SECTION_TEXTURE_PX;
    if (outW > PG_MAX_SECTION_TEXTURE_PX) outW = PG_MAX_SECTION_TEXTURE_PX;
    if (outH > PG_MAX_SECTION_TEXTURE_PX) outH = PG_MAX_SECTION_TEXTURE_PX;

    CGSize outputSize = CGSizeMake((CGFloat)outW, (CGFloat)outH);
    UIGraphicsBeginImageContextWithOptions(outputSize, NO, 1.0);
    CGContextRef ctx = UIGraphicsGetCurrentContext();
    UIImage *image = nil;
    if (ctx != NULL) {
        CGContextTranslateCTM(ctx, outputSize.width * 0.5, outputSize.height * 0.5);
        CGContextRotateCTM(ctx, (CGFloat)rotationDegrees * (CGFloat)M_PI / 180.0);
        CGContextTranslateCTM(ctx, -outputSize.width * 0.5, -outputSize.height * 0.5);

        CGFloat tileW = PG_TILE_TEXTURE_WIDTH_M * outputSize.width / (CGFloat)widthMeters;
        CGFloat tileH = PG_TILE_TEXTURE_HEIGHT_M * outputSize.height / (CGFloat)heightMeters;
        CGFloat diagonal = sqrt(
            outputSize.width * outputSize.width + outputSize.height * outputSize.height
        );
        CGRect drawRect = CGRectMake(
            -diagonal,
            -diagonal,
            outputSize.width + diagonal * 2.0,
            outputSize.height + diagonal * 2.0
        );
        for (CGFloat y = drawRect.origin.y; y < drawRect.origin.y + drawRect.size.height; y += tileH) {
            for (CGFloat x = drawRect.origin.x; x < drawRect.origin.x + drawRect.size.width; x += tileW) {
                [source drawInRect:CGRectMake(x, y, tileW, tileH)];
            }
        }
        image = UIGraphicsGetImageFromCurrentImageContext();
    }
    UIGraphicsEndImageContext();
    return image;
}

UIImage *pg_load_tile_texture_image(const char *resourceName, float rotationDegrees) {
    UIImage *source = PGLoadTileTextureSource(resourceName);
    return PGRotatedImage(source, (CGFloat)rotationDegrees);
}
