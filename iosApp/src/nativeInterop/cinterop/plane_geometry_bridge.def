headers = PlaneGeometryBridge.h
headerFilter = PlaneGeometryBridge.h
package = com.example.arplitka.iosapp.bridge
language = Objective-C
compilerOpts = -framework ARKit -framework Foundation -framework SceneKit
linkerOpts = -framework ARKit -framework Foundation -framework SceneKit

---

#import <ARKit/ARKit.h>
#import <SceneKit/SceneKit.h>
#import <math.h>
#import <stdint.h>
#import <string.h>
#import "PlaneGeometryBridge.h"

static ARPlaneAnchor *PGCast(void *planeAnchor) {
    if (planeAnchor == NULL) {
        return NULL;
    }
    return (__bridge ARPlaneAnchor *)planeAnchor;
}

static uint32_t PGHashFloat(float value) {
    uint32_t bits = 0;
    memcpy(&bits, &value, sizeof(bits));
    return bits;
}

static BOOL PGReadExtentBoundary(ARPlaneAnchor *anchor, vector_float3 *outVertices, NSUInteger *outCount) {
    if (anchor == NULL || outVertices == NULL || outCount == NULL) {
        return NO;
    }

    float width = 0.0f;
    float depth = 0.0f;
    float centerX = 0.0f;
    float centerZ = 0.0f;

    if (@available(iOS 16.0, *)) {
        width = anchor.planeExtent.width;
        depth = anchor.planeExtent.height;
    } else {
#pragma clang diagnostic push
#pragma clang diagnostic ignored "-Wdeprecated-declarations"
        width = anchor.extent.x;
        depth = anchor.extent.z;
        centerX = anchor.center.x;
        centerZ = anchor.center.z;
#pragma clang diagnostic pop
    }

    if (width <= 0.0f || depth <= 0.0f) {
        return NO;
    }

    float halfX = width * 0.5f;
    float halfZ = depth * 0.5f;
    outVertices[0] = (vector_float3){ centerX - halfX, 0.0f, centerZ - halfZ };
    outVertices[1] = (vector_float3){ centerX + halfX, 0.0f, centerZ - halfZ };
    outVertices[2] = (vector_float3){ centerX + halfX, 0.0f, centerZ + halfZ };
    outVertices[3] = (vector_float3){ centerX - halfX, 0.0f, centerZ + halfZ };
    *outCount = 4;
    return YES;
}

static BOOL PGReadPolygonBoundary(ARPlaneAnchor *anchor, const vector_float3 **outVertices, NSUInteger *outCount) {
    if (anchor == NULL || outVertices == NULL || outCount == NULL) {
        return NO;
    }

    ARPlaneGeometry *geometry = anchor.geometry;
    if (geometry != NULL && geometry.boundaryVertexCount >= 3 && geometry.boundaryVertices != NULL) {
        *outVertices = geometry.boundaryVertices;
        *outCount = geometry.boundaryVertexCount;
        return YES;
    }
    return NO;
}

static BOOL PGReadBoundary(ARPlaneAnchor *anchor, const vector_float3 **outVertices, NSUInteger *outCount, vector_float3 *fallbackVertices) {
    if (anchor == NULL || outVertices == NULL || outCount == NULL) {
        return NO;
    }

    if (PGReadPolygonBoundary(anchor, outVertices, outCount)) {
        return YES;
    }

    if (PGReadExtentBoundary(anchor, fallbackVertices, outCount)) {
        *outVertices = fallbackVertices;
        return YES;
    }
    return NO;
}

static BOOL PGPointInPolygonXZ(float x, float z, const vector_float3 *vertices, NSUInteger count) {
    if (vertices == NULL || count < 3) {
        return NO;
    }

    BOOL inside = NO;
    for (NSUInteger i = 0, j = count - 1; i < count; j = i++) {
        float xi = vertices[i].x;
        float zi = vertices[i].z;
        float xj = vertices[j].x;
        float zj = vertices[j].z;
        BOOL intersect = ((zi > z) != (zj > z)) &&
            (x < (xj - xi) * (z - zi) / ((zj - zi) + 1e-6f) + xi);
        if (intersect) {
            inside = !inside;
        }
    }
    return inside;
}

static float PGPolygonArea(const vector_float3 *vertices, NSUInteger count) {
    if (vertices == NULL || count < 3) {
        return 0.0f;
    }

    float sum = 0.0f;
    for (NSUInteger i = 0; i < count; i++) {
        NSUInteger next = (i + 1) % count;
        sum += vertices[i].x * vertices[next].z - vertices[next].x * vertices[i].z;
    }
    return fabsf(sum) * 0.5f;
}

#define PG_DOT_CIRCLE_SEGMENTS 12
#define PG_DOT_VERTICES_PER_DISC (1 + PG_DOT_CIRCLE_SEGMENTS)

typedef struct {
    float x;
    float y;
    float z;
} PGDotVertex;

static void PGWriteDotDisc(NSMutableData *vertexData, NSMutableData *indexData, int dotIndex, float x, float z, float dotRadiusM, float yOffsetM) {
    PGDotVertex center = { x, yOffsetM, z };
    PGDotVertex rim[PG_DOT_CIRCLE_SEGMENTS];
    for (int segment = 0; segment < PG_DOT_CIRCLE_SEGMENTS; segment++) {
        float angle = (float)segment * (2.0f * (float)M_PI / (float)PG_DOT_CIRCLE_SEGMENTS);
        rim[segment].x = x + cosf(angle) * dotRadiusM;
        rim[segment].y = yOffsetM;
        rim[segment].z = z + sinf(angle) * dotRadiusM;
    }

    uint16_t base = (uint16_t)(dotIndex * PG_DOT_VERTICES_PER_DISC);
    [vertexData appendBytes:&center length:sizeof(center)];
    [vertexData appendBytes:rim length:sizeof(rim)];

    for (int segment = 0; segment < PG_DOT_CIRCLE_SEGMENTS; segment++) {
        uint16_t indices[3] = {
            base,
            (uint16_t)(base + 1 + segment),
            (uint16_t)(base + 1 + ((segment + 1) % PG_DOT_CIRCLE_SEGMENTS))
        };
        [indexData appendBytes:indices length:sizeof(indices)];
    }
}

static SCNGeometry *PGCreateDotGeometryFromBuffers(NSMutableData *vertexData, NSMutableData *indexData, int dotCount) {
    if (dotCount <= 0 || vertexData.length == 0 || indexData.length == 0) {
        return nil;
    }

    SCNGeometrySource *source = [SCNGeometrySource geometrySourceWithData:vertexData
                                                                 semantic:SCNGeometrySourceSemanticVertex
                                                              vectorCount:(NSInteger)dotCount * PG_DOT_VERTICES_PER_DISC
                                                          floatComponents:YES
                                                      componentsPerVector:3
                                                        bytesPerComponent:sizeof(float)
                                                               dataOffset:0
                                                               dataStride:sizeof(PGDotVertex)];
    SCNGeometryElement *element = [SCNGeometryElement geometryElementWithData:indexData
                                                                primitiveType:SCNGeometryPrimitiveTypeTriangles
                                                               primitiveCount:(NSInteger)dotCount * PG_DOT_CIRCLE_SEGMENTS
                                                                bytesPerIndex:sizeof(uint16_t)];
    return [SCNGeometry geometryWithSources:@[source] elements:@[element]];
}

bool pg_anchor_has_polygon_boundary(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    return PGReadPolygonBoundary(anchor, &vertices, &count);
}

bool pg_local_point_in_render_boundary(void *planeAnchor, int boundaryMode, float localX, float localZ) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (boundaryMode == PG_DOT_BOUNDARY_POLYGON) {
        if (!PGReadPolygonBoundary(anchor, &vertices, &count) &&
            !PGReadExtentBoundary(anchor, fallback, &count)) {
            return false;
        }
        if (vertices == NULL) {
            vertices = fallback;
        }
    } else {
        if (!PGReadExtentBoundary(anchor, fallback, &count)) {
            return false;
        }
        vertices = fallback;
    }
    return PGPointInPolygonXZ(localX, localZ, vertices, count);
}

bool pg_local_point_in_polygon(void *planeAnchor, float localX, float localZ) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return false;
    }
    return PGPointInPolygonXZ(localX, localZ, vertices, count);
}

static uint32_t PGSignatureFromVertices(const vector_float3 *vertices, NSUInteger count) {
    uint32_t hash = (uint32_t)count;
    for (NSUInteger i = 0; i < count; i++) {
        hash = hash * 31u + PGHashFloat(vertices[i].x);
        hash = hash * 31u + PGHashFloat(vertices[i].z);
    }
    return hash;
}

uint32_t pg_geometry_signature(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return 0;
    }
    return PGSignatureFromVertices(vertices, count);
}

uint32_t pg_geometry_signature_extent(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    NSUInteger count = 0;
    if (!PGReadExtentBoundary(anchor, fallback, &count)) {
        return 0;
    }
    return PGSignatureFromVertices(fallback, count);
}

static int PGCollectWindowDotPoints(
    ARPlaneAnchor *anchor,
    int boundaryMode,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float *outLocalX,
    float *outLocalZ,
    int maxPoints
) {
    if (anchor == NULL || stepM <= 0.0f || maxPoints <= 0 || outLocalX == NULL || outLocalZ == NULL) {
        return 0;
    }

    vector_float3 extentFallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (boundaryMode == PG_DOT_BOUNDARY_POLYGON) {
        if (!PGReadPolygonBoundary(anchor, &vertices, &count) &&
            !PGReadExtentBoundary(anchor, extentFallback, &count)) {
            return 0;
        }
        if (vertices == NULL) {
            vertices = extentFallback;
        }
    } else {
        if (!PGReadExtentBoundary(anchor, extentFallback, &count)) {
            return 0;
        }
        vertices = extentFallback;
    }

    float minX = INFINITY;
    float maxX = -INFINITY;
    float minZ = INFINITY;
    float maxZ = -INFINITY;
    for (NSUInteger i = 0; i < count; i++) {
        float x = vertices[i].x;
        float z = vertices[i].z;
        if (x < minX) minX = x;
        if (x > maxX) maxX = x;
        if (z < minZ) minZ = z;
        if (z > maxZ) maxZ = z;
    }

    float radiusSq = maxRadiusM * maxRadiusM;
    int written = 0;
    for (float x = floorf(minX / stepM) * stepM; x <= maxX + stepM * 0.5f; x += stepM) {
        for (float z = floorf(minZ / stepM) * stepM; z <= maxZ + stepM * 0.5f; z += stepM) {
            float dx = x - refX;
            float dz = z - refZ;
            if ((dx * dx + dz * dz) > radiusSq) {
                continue;
            }
            if (!PGPointInPolygonXZ(x, z, vertices, count)) {
                continue;
            }
            outLocalX[written] = x;
            outLocalZ[written] = z;
            written++;
            if (written >= maxPoints) {
                return written;
            }
        }
    }
    return written;
}

int pg_generate_dot_points(
    void *planeAnchor,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float *outLocalX,
    float *outLocalZ,
    int maxPoints
) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    if (anchor == NULL || stepM <= 0.0f || maxPoints <= 0 || outLocalX == NULL || outLocalZ == NULL) {
        return 0;
    }

    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return 0;
    }

    float minX = INFINITY;
    float maxX = -INFINITY;
    float minZ = INFINITY;
    float maxZ = -INFINITY;
    for (NSUInteger i = 0; i < count; i++) {
        float x = vertices[i].x;
        float z = vertices[i].z;
        if (x < minX) minX = x;
        if (x > maxX) maxX = x;
        if (z < minZ) minZ = z;
        if (z > maxZ) maxZ = z;
    }

    float radiusSq = maxRadiusM * maxRadiusM;
    int written = 0;
    for (float x = floorf(minX / stepM) * stepM; x <= maxX + stepM * 0.5f; x += stepM) {
        for (float z = floorf(minZ / stepM) * stepM; z <= maxZ + stepM * 0.5f; z += stepM) {
            float dx = x - refX;
            float dz = z - refZ;
            if ((dx * dx + dz * dz) > radiusSq) {
                continue;
            }
            if (!PGPointInPolygonXZ(x, z, vertices, count)) {
                continue;
            }
            outLocalX[written] = x;
            outLocalZ[written] = z;
            written++;
            if (written >= maxPoints) {
                return written;
            }
        }
    }
    return written;
}

int pg_collect_window_dot_points(
    void *planeAnchor,
    int boundaryMode,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float *outLocalX,
    float *outLocalZ,
    int maxPoints
) {
    return PGCollectWindowDotPoints(
        PGCast(planeAnchor),
        boundaryMode,
        stepM,
        refX,
        refZ,
        maxRadiusM,
        outLocalX,
        outLocalZ,
        maxPoints
    );
}

float pg_polygon_area(void *planeAnchor) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    vector_float3 fallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (!PGReadBoundary(anchor, &vertices, &count, fallback)) {
        return 0.0f;
    }
    return PGPolygonArea(vertices, count);
}

static SCNGeometry *PGCreateDotMeshFromVertices(
    const vector_float3 *vertices,
    NSUInteger count,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float dotRadiusM,
    float yOffsetM,
    int maxPoints,
    int *outDotCount
) {
    if (outDotCount != NULL) {
        *outDotCount = 0;
    }
    if (vertices == NULL || count < 3 || stepM <= 0.0f || maxPoints <= 0 || dotRadiusM <= 0.0f) {
        return nil;
    }

    float minX = INFINITY;
    float maxX = -INFINITY;
    float minZ = INFINITY;
    float maxZ = -INFINITY;
    for (NSUInteger i = 0; i < count; i++) {
        float x = vertices[i].x;
        float z = vertices[i].z;
        if (x < minX) minX = x;
        if (x > maxX) maxX = x;
        if (z < minZ) minZ = z;
        if (z > maxZ) maxZ = z;
    }

    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPoints * PG_DOT_VERTICES_PER_DISC * sizeof(PGDotVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPoints * PG_DOT_CIRCLE_SEGMENTS * 3 * sizeof(uint16_t)];
    float radiusSq = maxRadiusM * maxRadiusM;
    int written = 0;
    for (float x = floorf(minX / stepM) * stepM; x <= maxX + stepM * 0.5f; x += stepM) {
        for (float z = floorf(minZ / stepM) * stepM; z <= maxZ + stepM * 0.5f; z += stepM) {
            float dx = x - refX;
            float dz = z - refZ;
            if ((dx * dx + dz * dz) > radiusSq) {
                continue;
            }
            if (!PGPointInPolygonXZ(x, z, vertices, count)) {
                continue;
            }
            PGWriteDotDisc(vertexData, indexData, written, x, z, dotRadiusM, yOffsetM);
            written++;
            if (written >= maxPoints) {
                if (outDotCount != NULL) {
                    *outDotCount = written;
                }
                return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
            }
        }
    }

    if (outDotCount != NULL) {
        *outDotCount = written;
    }
    return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
}

SCNGeometry *pg_create_dot_mesh_geometry(
    void *planeAnchor,
    int boundaryMode,
    float stepM,
    float refX,
    float refZ,
    float maxRadiusM,
    float dotRadiusM,
    float yOffsetM,
    int maxPoints,
    int *outDotCount
) {
    ARPlaneAnchor *anchor = PGCast(planeAnchor);
    if (anchor == NULL) {
        if (outDotCount != NULL) {
            *outDotCount = 0;
        }
        return nil;
    }

    vector_float3 extentFallback[4];
    const vector_float3 *vertices = NULL;
    NSUInteger count = 0;
    if (boundaryMode == PG_DOT_BOUNDARY_POLYGON) {
        if (!PGReadPolygonBoundary(anchor, &vertices, &count) &&
            !PGReadExtentBoundary(anchor, extentFallback, &count)) {
            if (outDotCount != NULL) {
                *outDotCount = 0;
            }
            return nil;
        }
        if (vertices == NULL) {
            vertices = extentFallback;
        }
    } else {
        if (!PGReadExtentBoundary(anchor, extentFallback, &count)) {
            if (outDotCount != NULL) {
                *outDotCount = 0;
            }
            return nil;
        }
        vertices = extentFallback;
    }

    return PGCreateDotMeshFromVertices(
        vertices,
        count,
        stepM,
        refX,
        refZ,
        maxRadiusM,
        dotRadiusM,
        yOffsetM,
        maxPoints,
        outDotCount
    );
}

SCNGeometry *pg_create_dot_mesh_local_disc(
    float centerX,
    float centerZ,
    float radiusM,
    float stepM,
    float dotRadiusM,
    float yOffsetM,
    int *outDotCount
) {
    if (outDotCount != NULL) {
        *outDotCount = 0;
    }
    if (radiusM <= 0.0f || stepM <= 0.0f || dotRadiusM <= 0.0f) {
        return nil;
    }

    int maxPoints = (int)(((radiusM * 2.0f / stepM) + 2.0f) * ((radiusM * 2.0f / stepM) + 2.0f));
    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPoints * PG_DOT_VERTICES_PER_DISC * sizeof(PGDotVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPoints * PG_DOT_CIRCLE_SEGMENTS * 3 * sizeof(uint16_t)];
    float radiusSq = radiusM * radiusM;
    int written = 0;
    for (float x = -radiusM; x <= radiusM + stepM * 0.5f; x += stepM) {
        for (float z = -radiusM; z <= radiusM + stepM * 0.5f; z += stepM) {
            if ((x * x + z * z) > radiusSq) {
                continue;
            }
            PGWriteDotDisc(vertexData, indexData, written, centerX + x, centerZ + z, dotRadiusM, yOffsetM);
            written++;
        }
    }

    if (outDotCount != NULL) {
        *outDotCount = written;
    }
    return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
}

SCNGeometry *pg_create_dot_mesh_from_points(
    const float *localX,
    const float *localZ,
    int pointCount,
    float dotRadiusM,
    float yOffsetM,
    int *outDotCount
) {
    if (outDotCount != NULL) {
        *outDotCount = 0;
    }
    if (localX == NULL || localZ == NULL || pointCount <= 0 || dotRadiusM <= 0.0f) {
        return nil;
    }

    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)pointCount * PG_DOT_VERTICES_PER_DISC * sizeof(PGDotVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)pointCount * PG_DOT_CIRCLE_SEGMENTS * 3 * sizeof(uint16_t)];
    int written = 0;
    for (int index = 0; index < pointCount; index++) {
        PGWriteDotDisc(vertexData, indexData, written, localX[index], localZ[index], dotRadiusM, yOffsetM);
        written++;
    }

    if (outDotCount != NULL) {
        *outDotCount = written;
    }
    return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
}

SCNGeometry *pg_create_preview_dot_mesh_geometry(
    float radiusM,
    float stepM,
    float dotRadiusM,
    float yOffsetM,
    int *outDotCount
) {
    if (outDotCount != NULL) {
        *outDotCount = 0;
    }
    if (radiusM <= 0.0f || stepM <= 0.0f || dotRadiusM <= 0.0f) {
        return nil;
    }

    int maxPreviewPoints = (int)(((radiusM * 2.0f / stepM) + 2.0f) * ((radiusM * 2.0f / stepM) + 2.0f));
    NSMutableData *vertexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPreviewPoints * PG_DOT_VERTICES_PER_DISC * sizeof(PGDotVertex)];
    NSMutableData *indexData = [NSMutableData dataWithCapacity:(NSUInteger)maxPreviewPoints * PG_DOT_CIRCLE_SEGMENTS * 3 * sizeof(uint16_t)];
    float radiusSq = radiusM * radiusM;
    int written = 0;
    for (float x = -radiusM; x <= radiusM + stepM * 0.5f; x += stepM) {
        for (float z = -radiusM; z <= radiusM + stepM * 0.5f; z += stepM) {
            if ((x * x + z * z) > radiusSq) {
                continue;
            }
            PGWriteDotDisc(vertexData, indexData, written, x, z, dotRadiusM, yOffsetM);
            written++;
        }
    }

    if (outDotCount != NULL) {
        *outDotCount = written;
    }
    return PGCreateDotGeometryFromBuffers(vertexData, indexData, written);
}
